function parentImportWideSheet(i){i=i||{};const id=PE_clean_(i.sourceSpreadsheetId),sname=PE_clean_(i.sourceSheetName||''),y=PE_clean_(i.academicYear),an=PE_clean_(i.activityName);if(!id)throw Error('ต้องระบุ Spreadsheet ID');if(!y)throw Error('ต้องระบุปีการศึกษา');if(!an)throw Error('ต้องระบุชื่อกิจกรรม');const ss=SpreadsheetApp.openById(id),sh=sname?ss.getSheetByName(sname):ss.getSheets()[0];if(!sh)throw Error('ไม่พบชีตต้นทาง');const v=sh.getDataRange().getDisplayValues();if(v.length<2)throw Error('ข้อมูลต้นทางไม่เพียงพอ');const h=v[0].map(PE_clean_),rows=v.slice(1),meta=PE_meta_(h),cols=PE_itemCols_(h,rows,meta.all);if(!cols.length)return{ok:false,status:'REVIEW',message:'ไม่พบคอลัมน์คะแนน 1-5'};const bad=cols.map(c=>h[c]).filter(PE_isBadItemText_);if(bad.length){PE_logQa_('importWideSheet','REVIEW','หัวข้อคำถามไม่สมบูรณ์',{badItems:bad});return{ok:false,status:'REVIEW',message:'พบ Q1/Q2/Column จึงหยุด import',badItems:bad}}const made=parentCreateActivity({academicYear:y,activityName:an,activityDate:i.activityDate||'',items:cols.map(c=>h[c])});if(!made.ok)return made;let imported=0,review=0;rows.forEach(r=>{const scores=cols.map(c=>r[c]);if(!scores.some(x=>String(x).trim()!==''))return;const z=parentSaveResponse({activityId:made.activityId,studentId:meta.studentId>=0?r[meta.studentId]:'',studentName:meta.studentName>=0?r[meta.studentName]:'',parentName:meta.parentName>=0?r[meta.parentName]:'',relationship:meta.relationship>=0?r[meta.relationship]:'',comments:meta.comments>=0?r[meta.comments]:'',scores});imported++;if(z.status!=='PASS')review++});PE_logQa_('importWideSheet',review?'REVIEW':'PASS','Import complete',{activityId:made.activityId,imported,review});return{ok:true,status:review?'REVIEW':'PASS',activityId:made.activityId,academicYear:y,activityName:an,itemCount:cols.length,importedResponses:imported,reviewResponses:review}}

function PE_find_(h,keys){const a=h.map(x=>String(x||'').toLowerCase());for(let i=0;i<a.length;i++)for(let k=0;k<keys.length;k++)if(a[i].includes(String(keys[k]).toLowerCase()))return i;return-1}
function PE_meta_(h){const o={studentId:PE_find_(h,['รหัสนักเรียน','รหัส','เลขที่','student id']),studentName:PE_find_(h,['ชื่อ-สกุลนักเรียน','ชื่อ-สกุล','ชื่อ สกุล','student name']),parentName:PE_find_(h,['ชื่อผู้ปกครอง','ผู้ปกครอง','parent']),relationship:PE_find_(h,['ความสัมพันธ์','relationship']),comments:PE_find_(h,['ข้อเสนอแนะ','ความคิดเห็น','comment']),timestamp:PE_find_(h,['ประทับเวลา','timestamp','เวลา'])};o.all=[o.studentId,o.studentName,o.parentName,o.relationship,o.comments,o.timestamp].filter(i=>i>=0);return o}
function PE_itemCols_(h,rows,meta){const m={};meta.forEach(i=>m[i]=1);const out=[];h.forEach((x,c)=>{if(m[c]||!PE_clean_(x))return;const n=rows.map(r=>Number(r[c])).filter(v=>isFinite(v)&&v>=1&&v<=5).length;if(n)out.push(c)});return out}